[Unit]
Description=CNC Probe — database maintenance (retention prune + VACUUM)
Documentation=https://github.com/bcrum81/MachineMonitor
After=cnc-probe.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/cnc-probe
ExecStart=/opt/cnc-probe/venv/bin/python3 /opt/cnc-probe/maintenance.py
Nice=10
IOSchedulingClass=idle
StandardOutput=journal
StandardError=journal
