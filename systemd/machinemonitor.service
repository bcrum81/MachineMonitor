[Unit]
Description=MachineMonitor CNC Shop Monitor
Documentation=https://github.com/bcrum81/MachineMonitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/MachineMonitor
ExecStart=/opt/MachineMonitor/venv/bin/python -m uvicorn app:app --host 0.0.0.0 --port 8765
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
KillSignal=SIGINT
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
