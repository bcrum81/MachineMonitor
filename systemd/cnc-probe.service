[Unit]
Description=CNC Probe — CNC Shop Monitor
Documentation=https://github.com/bcrum81/MachineMonitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/cnc-probe
ExecStart=/opt/cnc-probe/venv/bin/python app.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
KillSignal=SIGINT
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
